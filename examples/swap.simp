fn swap(a: ref Int, b: ref Int) -> Void {
    tmp := !a;
    a := !b;
    b := !tmp;
}

fn increment(x: ref Int) -> Void {
    x := !x + 1;
}

x := 10;
y := 20;
print "We're starting with x:=" + !x + " and y:=" + !y;
print "Swapping them.";
_ := swap(x, y);
print "Now we have x:=" + !x + " and y:=" + !y;

print "Incrementing x.";
_ := increment(x);
print "Now we have x:=" + !x + " and y:=" + !y;
