pd fizzbuzz(n) {
    i := 1;
    while !i <= !n do {
        if !i % 3 == 0 && !i % 5 == 0 then {
            print "Fizzbuzz!";
        } else {
            if !i % 3 == 0 then {
                print "Fizz";
            } else {
                if !i % 5 == 0 then {
                    print "Buzz";
                } else {
                    print !i;
                };
            };
        };
        i := !i + 1;
    };
}

call fizzbuzz(30);