fn fizzbuzz(n: Int) -> Void {
    i := 1;
    while !i <= !n do {
        fizz := (!i % 3) == 0;
        buzz := (!i % 5) == 0;
        if !fizz && !buzz then {
            print "fizzbuzz";
        } elif !fizz then {
            print "fizz";
        } elif !buzz then {
            print "buzz";
        } else {
            print !i;
        };
        i += 1;
    };
}

_ := fizzbuzz(30);