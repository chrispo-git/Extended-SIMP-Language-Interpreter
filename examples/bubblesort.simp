fn bubbleSort(arr: Int[]) -> Void {
    n := len(arr);
    i := 0;
    while !i < !n - 1 do {
        j := 0;
        while !j < !n - !i - 1 do {
            if arr[!j] > arr[!j + 1] then {
                tmp := arr[!j];
                arr[!j] := arr[!j + 1];
                arr[!j + 1] := !tmp;
            };
            j += 1;
        };
        i += 1;
    };
}