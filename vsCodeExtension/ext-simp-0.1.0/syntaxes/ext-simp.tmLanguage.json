{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SIMP+",
  "scopeName": "source.ext-simp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#types" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#namespace-call" },
    { "include": "#function-call" },
    { "include": "#struct-literal" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#variables" },
    { "include": "#null" }
  ],
  "repository": {
    "comments": {
      "patterns": [
          {
              "name": "comment.block.ext-simp",
              "begin": "/\\*",
              "end": "\\*/"
          },
          {
              "name": "comment.line.double-slash.ext-simp",
              "match": "//.*$"
          }
      ]
    },

    "strings": {
      "name": "string.quoted.double.ext-simp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ext-simp",
          "match": "\\\\[ntr\"\\\\]"
        }
      ]
    },

    "keywords-control": {
      "name": "keyword.control.ext-simp",
      "match": "\\b(if|elif|else|then|while|do|for|in|skip|break|continue|return|call|import|as|print)\\b"
    },

    "keywords-declaration": {
      "name": "storage.modifier.ext-simp",
      "match": "\\b(fn|struct|impl)\\b"
    },

    "types": {
      "patterns": [
        {
          "comment": "array types like Int[], Str[], Bool[]",
          "name": "storage.type.ext-simp",
          "match": "\\b(Int|Str|Bool|Float|Void)(?=\\s*\\[\\])"
        },
        {
          "comment": "primitive types",
          "name": "storage.type.ext-simp",
          "match": "\\b(Int|Str|Bool|Float|Void)\\b"
        },
        {
          "comment": "struct type names - capitalised identifiers in type position after colon or arrow",
          "name": "storage.type.ext-simp",
          "match": "(?<=:\\s*|->\\s*)[A-Z][a-zA-Z0-9_]*"
        }
      ]
    },

    "booleans": {
      "name": "constant.language.boolean.ext-simp",
      "match": "\\b(true|false)\\b"
    },

    "numbers": {
      "name": "constant.numeric.integer.ext-simp",
      "match": "-?\\b[0-9]+\\b"
    },

    "null": {
        "name": "constant.language.null.ext-simp",
        "match": "\\bnull\\b"
    },

    "namespace-call": {
      "comment": "namespace::function calls like math::factorial",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(::)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.namespace.ext-simp" },
        "2": { "name": "punctuation.accessor.ext-simp" },
        "3": { "name": "entity.name.function.ext-simp" }
      }
    },

    "function-call": {
      "comment": "regular function calls",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.ext-simp" }
      }
    },

    "struct-literal": {
      "comment": "struct instantiation - capitalised name followed by {",
      "match": "\\b([A-Z][a-zA-Z0-9_]*)(?=\\s*\\{)",
      "captures": {
        "1": { "name": "entity.name.type.ext-simp" }
      }
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.ext-simp",
          "match": ":=|\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.comparison.ext-simp",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.ext-simp",
          "match": "&&|\\|\\||¬"
        },
        {
          "name": "keyword.operator.arithmetic.ext-simp",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.dereference.ext-simp",
          "match": "!"
        },
        {
          "name": "keyword.operator.arrow.ext-simp",
          "match": "->"
        },
        {
          "name": "keyword.operator.namespace.ext-simp",
          "match": "::"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.accessor.ext-simp",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.ext-simp",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.ext-simp",
          "match": ","
        },
        {
          "name": "punctuation.definition.block.ext-simp",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.brackets.ext-simp",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.parameters.ext-simp",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.colon.ext-simp",
          "match": ":"
        }
      ]
    },

    "variables": {
      "name": "variable.other.ext-simp",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}